# Copy to .env.local for local dev, and set the same vars in Vercel project settings.
# Sports feeds are OPTIONAL (snapshot fallbacks exist). The Supabase/Stripe/OneSignal
# vars are required for the monetization features (auth, payments, predictions, push).

# --- Soccer (TheSportsDB) ---
# "123" is the free public key (server-side only — never expose to the browser).
TSDB_API_KEY=123
TSDB_API_BASE=https://www.thesportsdb.com/api
TSDB_PREMIUM=false

# --- F1 (Jolpica, no key) --- override only if you self-host an Ergast mirror.
# JOLPICA_BASE=https://api.jolpi.ca/ergast/f1/2026

# NBA & MLB use ESPN's public scoreboard JSON (no key, no config).

# Public site URL (used for absolute share/OG URLs).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Supabase (Postgres + Auth) — Project Settings → API ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=        # SECRET — bypasses RLS, server-only

# --- Stripe (one-time payments) — Developers → API keys / Products ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PERSONAL=            # $5 bundle  (price_…)
STRIPE_PRICE_PRO=                 # $20 bundle (price_…)
STRIPE_PRICE_COMBO=               # $22 combo  (price_…)

# --- Scoring cron + notifications ---
CRON_SECRET=                      # generate: openssl rand -hex 32
NEXT_PUBLIC_ONESIGNAL_APP_ID=
ONESIGNAL_REST_API_KEY=

# --- API-Sports.io (API-Football) — dashboard.api-football.com ---
APISPORTS_KEY=
