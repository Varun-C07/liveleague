# Copy to .env.local for local dev, and set the same vars in Vercel project settings.
# All vars are OPTIONAL — Live League runs with sensible defaults and falls back to
# per-sport snapshots if a feed is unreachable.

# --- Soccer (TheSportsDB) ---
# "123" is the free public key (server-side only — never expose to the browser).
# Replace with a Premium key to enable the v2 livescore feed.
TSDB_API_KEY=123
TSDB_API_BASE=https://www.thesportsdb.com/api
# Set to "true" only when TSDB_API_KEY is a Premium key (enables v2 livescore).
TSDB_PREMIUM=false

# --- F1 (Jolpica, no key) --- override only if you self-host an Ergast mirror.
# JOLPICA_BASE=https://api.jolpi.ca/ergast/f1/2026

# NBA & MLB use ESPN's public scoreboard JSON (no key, no config).

# Public site URL (used for absolute share/OG URLs).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
